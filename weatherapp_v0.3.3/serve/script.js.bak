// city data
async function loadCity(city) {

    const apiKey = "bbfa20e60e8096a6f0a910b572879eea";

    const response = await fetch(
        `https://api.openweathermap.org/data/2.5/weather?q=${city}&appid=${apiKey}&units=metric`
    );

    const data = await response.json();

    if (Number(data.cod) !== 200) {
        alert("City not found!");
        return;
    }

    const forecastResponse = await fetch(
        `https://api.openweathermap.org/data/2.5/forecast?q=${city}&appid=${apiKey}&units=metric`
    );

    const forecastData = await forecastResponse.json();

    if (forecastData.cod !== "200") {
        alert("Forecast data not found!");
        return;
    }

    document.getElementById("cityName").textContent = data.name;
    document.getElementById("weatherTemp").textContent = Math.round(data.main.temp) + "°C";
    document.getElementById("humidity").textContent = data.main.humidity + "%";
    document.getElementById("wind").textContent = data.wind.speed + " km/h";

    const temps = forecastData.list
        .slice(0, 7)
        .map(item => Math.round(item.main.temp));

    myChart.data.datasets[0].data = temps;
    myChart.update();

    addToHistory(city);
}

// chart
const ctx = document.getElementById('forecastChart');

let myChart = new Chart(ctx, {
    type: 'line',
    data: {
        labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
        datasets: [{
            label: 'Temperature °C',
            data: [18, 20, 22, 25, 23, 19, 17],
            borderWidth: 4,
            tension: 0.4,
            borderColor: '#0d6efd',
            backgroundColor: 'rgba(13,110,253,0.1)',
            fill: true
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false
    }
});

// search button
document.getElementById('searchBtn').addEventListener('click', function () {
    const val = document.getElementById('searchInput').value.trim();
    if (val === '') {
        alert('Please enter a city name!');
        return;
    }
    const cityName = val.charAt(0).toUpperCase() + val.slice(1);
    loadCity(cityName);
    document.getElementById('searchInput').value = '';
});

// enter key search
document.getElementById('searchInput').addEventListener('keydown', function (e) {
    if (e.key === 'Enter') {
        document.getElementById('searchBtn').click();
    }
});

// history
function addToHistory(city) {

    const tbody = document.getElementById('historyBody');
    const today = new Date().toLocaleDateString('tr-TR');
    const newRow = document.createElement('tr');

    newRow.innerHTML =
        '<td>' + city + '</td><td>' + today + '</td>';

    tbody.appendChild(newRow);

}

function removeFavorite(event, city) {

    event.stopPropagation();

    const card =
        document.querySelector(`[data-city="${city}"]`)
            .parentElement;

    card.remove();
}

// favorites
document.getElementById('addFavoriteBtn').addEventListener('click', function () {
    const city = document.getElementById('cityName').textContent;
    const container = document.getElementById('favoritesContainer');
    const temp = document.getElementById('weatherTemp').textContent;
    const exists = document.querySelector(`[data-city="${city}"]`);

    if (exists) {
        alert("This city is already in favorites!");
        return;
    }

    const card = document.createElement('div');

    card.className = 'col-lg-4';

    card.innerHTML = `
    <div class="favorite-card"
         data-city="${city}"
         onclick="loadCity('${city}')">

        <div class="city-icon">⭐</div>

        <h5>${city}</h5>

        <h3>${temp}</h3>

        <button
            class="btn btn-danger btn-sm mt-2"
            onclick="removeFavorite(event,'${city}')">
            Remove
        </button>

    </div>
    `;

    container.appendChild(card);

});

// dark mode
document.getElementById('themeToggle').addEventListener('click', function () {
    document.body.classList.toggle('dark-mode');
    if (document.body.classList.contains('dark-mode')) {
        this.textContent = '☀️ Light Mode';
    } else {
        this.textContent = '🌙 Dark Mode';
    }
});

// default city
loadCity("Wroclaw");